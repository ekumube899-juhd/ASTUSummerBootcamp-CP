t = int(input())
for _ in range(t):
    n = int(input())
    a = list(map(int, input().split()))
    a.sort()
    blue = a[0]
    red = 0
    left = 1
    right = n - 1
    while left < right:
        blue += a[left]
        red += a[right]
        if red > blue:
            print("YES")
            break
        left += 1
        right -= 1
    else:
        print("NO")
