class Solution:
    def reverseWords(self, s: str) -> str:
         words = s.split(" ")
         for i in range(len(words)):
            word_list = list(words[i])
            left = 0
            right = len(word_list) - 1
            while left < right:
                word_list[left], word_list[right] = word_list[right], word_list[left]
                left += 1
                right -= 1
            words[i] = "".join(word_list)
         return " ".join(words)
