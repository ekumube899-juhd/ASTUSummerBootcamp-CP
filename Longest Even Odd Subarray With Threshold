class Solution:
    def longestAlternatingSubarray(self, nums: List[int], threshold: int) -> int:
        answer = 0
        i = 0
        while i < len(nums):
            if nums[i] % 2 != 0 or nums[i] > threshold:
                i += 1
                continue
            count = 1
            j = i + 1
            while j < len (nums):
                if nums[j] > threshold:
                    break
                if nums[j] % 2 == nums[j - 1] % 2:
                    break
                count += 1
                j += 1
            answer = max(answer, count)
            i += 1
        return answer       
