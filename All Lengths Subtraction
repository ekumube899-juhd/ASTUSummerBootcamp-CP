t = int(input())
for _ in range(t):
    n = int(input())
    p = list(map(int, input().split()))
    l = 0
    r = n - 1
    ok = True
    for x in range(1, n + 1):
        if p[l] == x:
            l += 1
        elif p[r] == x:
            r -= 1
        else:
            ok = False
            break
    if ok:
        print("YES")
    else:
        print("NO")
