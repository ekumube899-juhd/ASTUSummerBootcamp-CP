class Solution:
    def minPairSum(self, nums: List[int]) -> int:
        nums.sort()
        left = 0
        right = len(nums) - 1
        max = 0
        while left < right:
            pair_sum = nums[left] + nums[right]
            if pair_sum > max:
                max = pair_sum
            left += 1
            right -= 1
        return max
