t = int(input())
for _ in range(t):
    n = int(input())
    a = list(map(int, input(). split()))
    max_num = a[0]
    min_num = a[0]
    for i in range(1,n):
        if a[i] > max_num:
            max_num = a[i]
        if a[i] < min_num:
            min_num = a[i]
    distance = max_num - min_num
    answer = (distance + 1) // 2
    print(answer)
